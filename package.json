{
  "name": "edge-clone",
  "version": "0.1.0",
  "description": "Clone any web page into a speed-optimized static site with deferred tracking. Sub-1-second loads.",
  "type": "module",
  "bin": {
    "edge-clone": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pagespeed",
    "clone",
    "static-site",
    "edge",
    "performance",
    "tracking",
    "marketing"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
