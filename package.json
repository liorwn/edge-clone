{
  "name": "andale-cli",
  "version": "0.1.0",
  "description": "Clone any web page into a speed-optimized static site. Pixel-perfect rendering, deferred tracking, sub-1-second loads.",
  "type": "module",
  "bin": {
    "andale": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vitest run && tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test",
    "test:unit": "vitest run"
  },
  "keywords": [
    "pagespeed",
    "clone",
    "static-site",
    "edge",
    "performance",
    "tracking",
    "marketing",
    "lighthouse",
    "web-vitals",
    "optimization",
    "seo",
    "landing-page"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liorwn/andale.git"
  },
  "homepage": "https://github.com/liorwn/andale#readme",
  "bugs": {
    "url": "https://github.com/liorwn/andale/issues"
  },
  "author": "Lior Weinstein <lior@cto.com>",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "clean-css": "^5.3.3",
    "commander": "^14.0.3",
    "html-minifier-terser": "^7.2.0",
    "lighthouse": "^13.0.3",
    "ora": "^9.3.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
